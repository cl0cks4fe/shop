[Unit]
Description=Gadget
After=systemd-udevd.service
Wants=systemd-udevd.service
ConditionPathExists=/gadget.img

[Service]
Type=oneshot
ExecStartPre=modprobe -r g_mass_storage
ExecStart=modprobe g_mass_storage file=/gadget.img removable=1 stall=0
ExecStop=modprobe -r g_mass_storage
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target